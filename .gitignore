*.zip
*.csv
*.tsv
*.parquet
dumps/                        # dumps do Postgres
*.dump
*.backup

# ATENÇÃO: não ignore *.sql de forma ampla.
# DDL, migrations e views materializadas são CÓDIGO e devem ser versionados
# (init_indexes.sql, mv_comparador_uf_kpis.sql).
dumps/*.sql

