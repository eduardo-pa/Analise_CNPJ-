# Copie este arquivo para .env e preencha com os valores reais.
# O .env está no .gitignore e nunca deve ser commitado.

DATABASE_URL=postgresql://usuario:senha@localhost:5432/tcc_cnpj

# Pasta com os ZIPs da Receita Federal (Empresas0..9, Estabelecimentos0..9, etc.)
CNPJ_DIR=C:\Users\SEU_USUARIO\caminho\para\2026-02\2026-02

# OPCIONAL — disco alternativo para as tabelas bronze (~40 GB transitórios).
# Deixe em branco para usar o volume padrão do PostgreSQL.
# A pasta precisa EXISTIR, estar VAZIA, e a conta de serviço do PostgreSQL
# precisa ter Controle Total sobre ela (Propriedades > Segurança no Windows).
# A camada Gold permanece sempre no volume padrão, por ser a consultada.
CNPJ_TABLESPACE_DIR=
